@model  IEnumerable<PeluqueriaCanina.Models.Venta>

@{
    ViewData["Title"] = "Historial de Ventas";
}

<h1>Historial de Ventas</h1>

<p>
    <!-- Corregido para que apunte al catálogo de productos a iniciar una nueva compra -->
    <a asp-controller="Productos" asp-action="Index" class="btn btn-primary">Registrar Nueva Venta</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fecha)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cliente)
            </th>
            <th>
                Cantidad de Ítems
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Total)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MetodoPago)
            </th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Fecha)
            </td>
            <td>
                <!-- Corregido: Se accede a la propiedad Nombre o Email del cliente si hereda de IdentityUser -->
                @(item.Cliente != null ? item.Cliente.NombreCompleto : "Cliente General")
            </td>
            <td>
                <!-- Corregido: Muestra la cantidad de productos distintos en el detalle -->
                @(item.Detalle != null ? item.Detalle.Count : 0)
            </td>
            <td>
                <!-- Formateado como moneda -->
                @item.Total.ToString("C")
            </td>
            <td>
                @Html.DisplayFor(model => item.MetodoPago)
            </td>
            <td>
                <!-- Mantenemos Edit, Details y Delete que sí existen en tu controlador -->
                <a asp-action="Edit" asp-route-id="@item.Id" class="text-warning">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="text-info">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>