@model IEnumerable<PeluqueriaCanina.Models.Producto>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Precio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Categoria)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PresentacionComercial)
            </th>
            <th>Acciones de Administración</th>
            <th>Acciones de Compra</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(model => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Descripcion)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Precio)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Stock)
                </td>
                <td>
                    @Html.DisplayFor(model => item.Categoria)
                </td>
                <td>
                    @Html.DisplayFor(model => item.PresentacionComercial)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
                <td>
                    @if (item.Stock > 0)
                    {
                        <a asp-controller="Carrito" asp-action="Agregar" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            🛒 Agregar al Carrito
                        </a>
                    }
                    else
                    {
                        <span class="badge bg-danger">Sin Stock</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>