@{
    ViewData["Title"] = "Verificación de Empleado";
    dynamic viewModel = Model;
    ApplicationUser user = viewModel.user;
    Empleado empleado = viewModel.empleado;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-tie"></i> Información del Empleado
                    </h4>
                </div>
                <div class="card-body">
                    @if (empleado != null)
                    {
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Nombre Completo</h6>
                                <p><strong>@empleado.Nombre @empleado.Apellido</strong></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">DNI</h6>
                                <p><strong>@empleado.Dni</strong></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Email</h6>
                                <p><strong>@user.Email</strong></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Teléfono</h6>
                                <p><strong>@empleado.Telefono</strong></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Legajo</h6>
                                <p><strong>@empleado.Legajo</strong></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Puesto</h6>
                                <p><strong>@empleado.Puesto</strong></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Sueldo</h6>
                                <p><strong>$@empleado.Sueldo.ToString("N2")</strong></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Estado de Cuenta</h6>
                                <p>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-pause-circle"></i> Inactivo
                                        </span>
                                    }
                                </p>
                            </div>
                        </div>

                        <hr />

                        <div class="d-grid gap-2">
                            @if (user.IsActive)
                            {
                                <form method="post" action="@Url.Action("DesactivarEmpleado", "Admin")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-warning btn-lg" 
                                            onclick="return confirm('¿Desactivar a este empleado?');">
                                        <i class="fas fa-lock"></i> Desactivar Empleado
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="@Url.Action("ActivarEmpleado", "Admin")">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-success btn-lg">
                                        <i class="fas fa-unlock"></i> Activar Empleado
                                    </button>
                                </form>
                            }

                            <a href="@Url.Action("Empleados", "Admin")" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Volver a Lista
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> 
                            No se encontraron datos del empleado.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
