@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Gestión de Empleados";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="fas fa-users-cog"></i> Gestión de Empleados
            </h1>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Email</th>
                                <th>Estado</th>
                                <th>Tipo Usuario</th>
                                <th>Fecha Registro</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var empleado in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@empleado.Email</strong>
                                    </td>
                                    <td>
                                        @if (empleado.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">
                                                <i class="fas fa-pause-circle"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@empleado.TipoUsuario</span>
                                    </td>
                                    <td>
                                        @empleado.LockoutEnd?.DateTime.ToString("dd/MM/yyyy") ?? "N/A"
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("VerificacionEmpleado", new { id = empleado.Id })" 
                                               class="btn btn-info" title="Ver Detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            @if (empleado.IsActive)
                                            {
                                                <form method="post" action="@Url.Action("DesactivarEmpleado")" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@empleado.Id" />
                                                    <button type="submit" class="btn btn-warning" title="Desactivar" 
                                                            onclick="return confirm('¿Estás seguro de desactivar a este empleado?');">
                                                        <i class="fas fa-lock"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" action="@Url.Action("ActivarEmpleado")" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@empleado.Id" />
                                                    <button type="submit" class="btn btn-success" title="Activar">
                                                        <i class="fas fa-unlock"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No hay empleados registrados en el sistema.
                </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-group-sm .btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }
</style>
