@model PeluqueriaCanina.Models.Carrito

@{
    ViewData["Title"] = "Carrito de Compras";
}

<h1>Carrito de Compras</h1>

@if (Model == null || !Model.Items.Any())
{
    <div class="alert alert-info">
        <p>Items: 0</p>
        <p>Total: $0.00</p>
        <p>El carrito está vacío. <a asp-controller="Productos" asp-action="Index">Volver al catálogo</a></p>
    </div>
}
else
{
    <div class="mb-3 text-end">
        <!-- Corregido a enlace simple GET -->
        <a asp-controller="Carrito" asp-action="Vaciar" class="btn btn-danger">Vaciar Carrito</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Precio</th>
                <th>Cantidad</th>
                <th>Subtotal</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Producto?.Nombre</td>
                    <td>@item.Producto?.Precio.ToString("C")</td>
                    <td>@item.Cantidad</td>
                    <td>@item.Subtotal.ToString("C")</td>
                    <td>
                        <!-- Corregido a enlace simple GET -->
                        <a asp-controller="Carrito" asp-action="Eliminar" asp-route-id="@item.Producto?.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-end font-weight-bold"><strong>Total General:</strong></td>
                <td colspan="2" class="font-weight-bold"><strong>@Model.Total.ToString("C")</strong></td>
            </tr>
        </tfoot>
    </table>

    <div class="mt-4 text-end">
        <a asp-controller="Productos" asp-action="Index" class="btn btn-secondary">Seguir Comprando</a>
        <!-- ¡CORREGIDO AQUÍ! Ahora apunta correctamente a Checkout -->
        <a asp-controller="Ventas" asp-action="Checkout" class="btn btn-primary">Iniciar Venta</a>
    </div>
}