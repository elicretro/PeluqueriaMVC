@model PeluqueriaCanina.Models.Turno

@{
    ViewData["Title"] = "Editar Turno";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Editar Turno</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdTurno" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FechaHora" class="form-label fw-bold">Horario del Turno</label>

                        @if (Model.Estado == EstadoTurno.Pendiente)
                        {
                            <input asp-for="FechaHora"
                                   class="form-control"
                                   type="datetime-local"
                                   id="fechaHoraInput"
                                   value="@Model.FechaHora.ToString("yyyy-MM-ddTHH:mm")" />
                        }
                        else
                        {
                            <input asp-for="FechaHora"
                                   class="form-control-plaintext border-bottom fw-bold"
                                   type="datetime-local"
                                   id="fechaHoraInput"
                                   value="@Model.FechaHora.ToString("yyyy-MM-ddTHH:mm")"
                                   readonly />
                            <span class="badge bg-warning text-dark mt-2">
                                No se puede reprogramar un turno con estado: @Model.Estado
                            </span>
                        }
                        <span asp-validation-for="FechaHora" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Empleado"))
                    {
                        <div class="col-md-6 mb-3">
                            <label asp-for="ClienteId" class="form-label fw-bold">Cliente</label>
                            <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId">
                                <option value="">-- Seleccione un Cliente --</option>
                            </select>
                            <span asp-validation-for="ClienteId" class="text-danger"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="ClienteId" />
                    }
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="MascotaId" class="form-label fw-bold">Mascota</label>
                        <select asp-for="MascotaId" class="form-select" asp-items="ViewBag.MascotaId">
                            <option value="">-- Seleccione una Mascota --</option>
                        </select>
                        <span asp-validation-for="MascotaId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Tipo" class="form-label fw-bold">Tipo de Servicio</label>
                        <select asp-for="Tipo" id="tipoServicioSelect" class="form-select" asp-items="ViewBag.TipoServicioList">
                            <option value="">-- Seleccione el Tipo de Servicio --</option>
                        </select>
                        <span asp-validation-for="Tipo" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="EmpleadoId" class="form-label fw-bold">Empleado Asignado</label>
                        <select asp-for="EmpleadoId" id="empleadoSelect" class="form-select" asp-items="ViewBag.EmpleadoId">
                            <option value="">-- Primero elija un servicio --</option>
                        </select>
                        <span asp-validation-for="EmpleadoId" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Empleado"))
                    {
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="form-label fw-bold">Estado del Turno</label>
                            <select asp-for="Estado" class="form-select" asp-items="ViewBag.EstadoTurnoList">
                                <option value="">-- Seleccione el Estado --</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="Estado" />
                    }
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary px-4">Guardar Cambios</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Volver</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tipoServicioSelect = document.getElementById("tipoServicioSelect");
            const empleadoSelect = document.getElementById("empleadoSelect");

            // Guardamos el ID del empleado que ya tiene asignado el turno actualmente
            const empleadoActualId = "@Model.EmpleadoId";

            // =======================================================
            // FILTRADO DINÁMICO DE EMPLEADOS (Igual que en Create)
            // =======================================================
            async function cargarEmpleados(mantenerSeleccionado = false) {
                const tipoServicio = tipoServicioSelect.value;

                if (!tipoServicio) {
                    empleadoSelect.innerHTML = '<option value="">-- Primero elija un servicio --</option>';
                    return;
                }

                try {
                    const url = `/Turnos/GetEmpleadosPorServicio?tipoServicio=${tipoServicio}`;
                    const response = await fetch(url);
                    if (!response.ok) throw new Error("Error en la petición.");

                    const empleados = await response.json();

                    empleadoSelect.innerHTML = '<option value="">-- Seleccione un Empleado --</option>';

                    empleados.forEach(emp => {
                        const option = document.createElement("option");
                        option.value = emp.id;
                        option.textContent = emp.nombreCompleto;

                        // Si estamos en la carga inicial y el ID coincide con el del modelo, lo preseleccionamos
                        if (mantenerSeleccionado && emp.id.toString() === empleadoActualId) {
                            option.selected = true;
                        }

                        empleadoSelect.appendChild(option);
                    });

                } catch (error) {
                    console.error("Error cargando empleados:", error);
                }
            }

            // Escuchar cambios de servicio
            tipoServicioSelect.addEventListener("change", () => cargarEmpleados(false));

            // Carga inicial al entrar a la vista (mantiene el empleado guardado originalmente)
            if (tipoServicioSelect.value) {
                cargarEmpleados(true);
            }
        });
    </script>
}