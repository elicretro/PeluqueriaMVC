@model IEnumerable<PeluqueriaCanina.Models.Turno>

@{
    ViewData["Title"] = "Turnos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Gestión de Turnos</h1>
        <a asp-action="Create" class="btn btn-primary">Nuevo Turno</a>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Resumen de la Cita</th>
                <th>Empleado Asignado</th>
                <th class="text-center">Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                        No hay turnos agendados por el momento.
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="fs-6 fw-bold">@item.ResumenCita</span>
                        </td>
                        <td>
                            @if (item.Empleado != null)
                            {
                                <span>@item.Empleado.Apellido, @item.Empleado.Nombre</span>
                            }
                            else
                            {
                                <span class="text-muted">Sin asignar</span>
                            }
                        </td>
                        <td class="text-center">
                            @{
                                string badgeClass = "bg-secondary";
                                string estadoStr = item.Estado.ToString().ToLower();

                                if (estadoStr == "pendiente")
                                {
                                    badgeClass = "bg-warning text-dark";
                                }
                                else if (estadoStr == "confirmado")
                                {
                                    badgeClass = "bg-success";
                                }
                                else if (estadoStr == "cancelado")
                                {
                                    badgeClass = "bg-danger";
                                }
                                else if (estadoStr == "ausente")
                                {
                                    badgeClass = "bg-dark";
                                }
                            }
                            <span class="badge @badgeClass">@item.Estado</span>
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="Details" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-info text-white">Detalles</a>
                                <a asp-action="Delete" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-danger">Eliminar</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>