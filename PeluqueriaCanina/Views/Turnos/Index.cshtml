@model IEnumerable<PeluqueriaCanina.Models.Turno>

@{
    ViewData["Title"] = "Turnos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-0">Gestión de Turnos</h1>
            <p class="text-muted">Administración y control de citas de la peluquería</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-calendar-plus"></i> Nuevo Turno
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Resumen de la Cita</th>
                        <th>Empleado Asignado</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                                No hay turnos agendados por el momento.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fs-6 fw-bold text-dark">@item.ResumenCita</span>
                                </td>
                                <td>
                                    @if (item.Empleado != null)
                                    {
                                        <span class="fw-semibold text-secondary">@item.Empleado.Apellido, @item.Empleado.Nombre</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sin asignar</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @{
                                        string badgeClass = "bg-secondary";
                                        string estadoStr = item.Estado.ToString().ToLower();

                                        if (estadoStr == "pendiente")
                                        {
                                            badgeClass = "bg-warning text-dark";
                                        }
                                        else if (estadoStr == "confirmado")
                                        {
                                            badgeClass = "bg-success";
                                        }
                                        else if (estadoStr == "cancelado")
                                        {
                                            badgeClass = "bg-danger";
                                        }
                                        else if (estadoStr == "ausente")
                                        {
                                            badgeClass = "bg-dark";
                                        }
                                    }
                                    <span class="badge px-3 py-2 rounded-pill @badgeClass">@item.Estado</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group" aria-label="Acciones de turno">
                                        <a asp-action="Edit" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-outline-warning">
                                            Editar
                                        </a>
                                        <a asp-action="Details" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-outline-info">
                                            Detalles
                                        </a>
                                        <a asp-action="Delete" asp-route-idturno="@item.IdTurno" class="btn btn-sm btn-outline-danger">
                                            Eliminar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>