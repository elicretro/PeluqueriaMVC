@model PeluqueriaCanina.Models.Mascota

@{
    ViewData["Title"] = "Eliminar Mascota";
}

<div class="container mt-4">
    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">¿Estás seguro de que querés eliminar esta mascota?</h3>
        </div>
        <div class="card-body">
            <h4 class="card-title text-muted">Datos de la Mascota</h4>
            <hr />

            <dl class="row fs-6">
                <dt class="col-sm-3 fw-bold text-secondary">Nombre</dt>
                <dd class="col-sm-9">@Model.Nombre</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Edad</dt>
                <dd class="col-sm-9">@Model.Edad años</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Tipo</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-secondary">@Model.Tipo</span>
                </dd>

                <dt class="col-sm-3 fw-bold text-secondary">Raza</dt>
                <dd class="col-sm-9">@Model.Raza</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Identificación</dt>
                <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Identificacion) ? "No posee" : Model.Identificacion)</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Peso</dt>
                <dd class="col-sm-9">@Model.Peso Kg</dd>
            </dl>
        </div>
        <div class="card-footer bg-light d-flex justify-content-end">
            <form asp-action="Delete">
                @* Para blindar la petición, enviamos el ID usando 'name="id"' y 'name="idmascota"'.
                  De esta forma, no importa cómo se llame el parámetro en tu controlador, lo va a recibir igual.
                *@
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="idmascota" value="@Model.Id" />

                <button type="submit" class="btn btn-danger">Confirmar Eliminar</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>