@model PeluqueriaCanina.Models.Persona

@{
    ViewData["Title"] = "Detalles de Persona";
}

<div class="container mt-4">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Detalles de la Persona</h3>
            <span class="badge bg-light text-primary fw-bold">
                @(Model is PeluqueriaCanina.Models.Empleado ? "Empleado" : "Cliente")
            </span>
        </div>
        <div class="card-body">
            <dl class="row fs-6 mb-0">
                <dt class="col-sm-3 fw-bold text-secondary">Nombre</dt>
                <dd class="col-sm-9">@Model.Nombre</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Apellido</dt>
                <dd class="col-sm-9">@Model.Apellido</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3 fw-bold text-secondary">DNI</dt>
                <dd class="col-sm-9">@Model.Dni</dd>

                <dt class="col-sm-3 fw-bold text-secondary">Teléfono</dt>
                <dd class="col-sm-9">@Model.Telefono</dd>

                @if (Model is PeluqueriaCanina.Models.Empleado empleado)
                {
                    <dt class="col-sm-3 fw-bold text-secondary">Puesto / Cargo</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-dark">@empleado.Puesto</span>
                    </dd>

                    <dt class="col-sm-3 fw-bold text-secondary">Especialidad</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-secondary">@empleado.Especialidad</span>
                    </dd>
                }
            </dl>
        </div>
        <div class="card-footer bg-light d-flex justify-content-end">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Editar Datos</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Volver al Listado</a>
        </div>
    </div>

    @if (Model is PeluqueriaCanina.Models.Cliente cliente)
    {
        <div class="card shadow-sm border-info mt-4">
            <div class="card-header bg-info text-dark d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-paw"></i> Mascotas Registradas</h4>
                <a asp-controller="Mascotas" asp-action="Create" asp-route-idCliente="@Model.Id" class="btn btn-light btn-sm fw-bold">
                    + Agregar Mascota
                </a>
            </div>
            <div class="card-body p-0">
                @if (cliente.Mascotas != null && cliente.Mascotas.Any())
                {
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Nombre</th>
                                <th>Edad</th>
                                <th>Tipo</th>
                                <th>Raza</th>
                                <th>Peso</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mascota in cliente.Mascotas)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@mascota.Nombre</td>
                                    <td>@mascota.Edad años</td>
                                    <td><span class="badge bg-secondary">@mascota.Tipo</span></td>
                                    <td>@mascota.Raza</td>
                                    <td>@mascota.Peso kg</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Mascotas"
                                               asp-action="Edit"
                                               asp-route-id="@mascota.Id"
                                               asp-route-idCliente="@Model.Id"
                                               class="btn btn-sm btn-outline-warning">
                                                Editar
                                            </a>
                                            <a asp-controller="Mascotas"
                                               asp-action="Delete"
                                               asp-route-id="@mascota.Id"
                                               asp-route-idCliente="@Model.Id"
                                               class="btn btn-sm btn-outline-danger">
                                                Eliminar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <p class="mb-0 fs-5">Este cliente todavía no tiene mascotas registradas.</p>
                        <p class="small text-muted">Hacé clic en "Agregar Mascota" para registrar la primera.</p>
                    </div>
                }
            </div>
        </div>
    }
</div>