@model PeluqueriaCanina.Models.Persona

@{
    ViewData["Title"] = "Eliminar Persona";
}

<h1>Eliminar</h1>
<h3>¿Estás seguro de que querés eliminar a esta persona?</h3>

<div>
    <h4>Persona</h4>
    <hr />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Nombre)</dd>

        <dt class="col-sm-2">Apellido</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Apellido)</dd>

        <dt class="col-sm-2">DNI / Documento</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Dni)</dd>

        <dt class="col-sm-2">Correo Electrónico</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Email)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar Definitivamente</button> |
        <a asp-action="Index" class="btn btn-secondary">Volver al Listado</a>
    </form>
</div>