@{
    ViewData["Title"] = "Sesión Cerrada";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-success">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">✓ Sesión Cerrada</h3>
                </div>
                <div class="card-body text-center">
                    <p class="lead mb-4">
                        Tu sesión ha sido cerrada correctamente.
                    </p>

                    <div class="alert alert-info">
                        <p>Vuelve a iniciar sesión siempre que desees acceder a tu cuenta.</p>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">Volver al Inicio</a>
                        <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-primary">Iniciar Sesión</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 10px;
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }
</style>
