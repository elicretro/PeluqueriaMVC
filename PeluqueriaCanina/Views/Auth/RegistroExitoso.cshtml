@{
    ViewData["Title"] = "Registro Exitoso";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-success">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">✓ Registro Exitoso</h3>
                </div>
                <div class="card-body text-center">
                    <p class="lead mb-4">
                        ¡Tu registro como empleado ha sido completado exitosamente!
                    </p>

                    <div class="alert alert-info">
                        <strong><i class="fas fa-info-circle"></i> Información Importante:</strong>
                        <p>Tu cuenta está <strong>activa y lista para usar</strong>. El administrador podrá revisar tu perfil y hacer cambios si es necesario.</p>
                        <p>Puedes intentar iniciar sesión ahora mismo con tu email y contraseña.</p>
                    </div>

                    <p class="text-muted mb-4">
                        Si experimentas problemas al iniciar sesión, verifica tu email y contraseña, o contacta al administrador.
                    </p>

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Login", "Auth")" class="btn btn-success btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Iniciar Sesión Ahora
                        </a>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary">Volver al Inicio</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-radius: 10px;
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }
</style>
